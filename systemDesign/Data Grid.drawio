        <mxCell id="eWhCHk_YGbrnsQgAyRc3-1" parent="1" style="text;strokeColor=none;fillColor=none;html=1;fontSize=84;fontStyle=1;verticalAlign=middle;align=center;autosizeText=1;" value="&lt;p style=&quot;margin: 0.0px 0.0px 2.0px 0.0px; font: 16.0px &#39;Helvetica Neue&#39;&quot;&gt;&lt;b&gt;Design a High-Performance Enterprise Data Grid / Compliance Dashboard&lt;/b&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="740" x="720" y="20" as="geometry" />
        </mxCell>
        <mxCell id="eWhCHk_YGbrnsQgAyRc3-3" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Requirements / Scope&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;User should be able to use our component to render a table&lt;br&gt;&lt;/li&gt;&lt;li&gt;User should be able to load async data&lt;/li&gt;&lt;li&gt;User should be able to apply sort by any column&lt;/li&gt;&lt;li&gt;User should be able to render dynamic content for each column value&lt;/li&gt;&lt;li&gt;User should be able to style each column, cell, table, etc&lt;/li&gt;&lt;li&gt;Our component should take schema of the columns&lt;/li&gt;&lt;li&gt;Our component should support pagination / infinite scrolling&lt;/li&gt;&lt;li&gt;Our component should show loader or error&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="180" width="420" x="60" y="81" as="geometry" />
        </mxCell>
        <mxCell id="eWhCHk_YGbrnsQgAyRc3-4" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Tech Stack&lt;/h1&gt;&lt;p&gt;State Management: Jotai (so that reference of each row data can be stored to prevent re-render on row data change)&lt;/p&gt;&lt;p&gt;HTML Element: Grid (because table has very strict structure and is not easy to implement virtualisation on it)&lt;/p&gt;&lt;p&gt;State Management: local using useState hook&lt;/p&gt;&lt;p&gt;Theming/Styling: Custom&lt;/p&gt;" vertex="1">
          <mxGeometry height="239" width="260" x="70" y="282" as="geometry" />
        </mxCell>
