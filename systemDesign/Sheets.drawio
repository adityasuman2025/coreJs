        <mxCell id="v2OB34sA-GqR4EwWEd6K-54" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 style=&quot;caret-color: rgb(0, 0, 0); color: rgb(0, 0, 0); font-family: Helvetica; font-style: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-line: none; text-decoration-thickness: auto; text-decoration-style: solid; margin-top: 0px;&quot;&gt;Performance &amp;amp; Optimization&amp;nbsp;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="40" width="360" x="1320" y="580" as="geometry" />
        </mxCell>
        <mxCell id="v2OB34sA-GqR4EwWEd6K-56" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;ol&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Network Performance&lt;/li&gt;&lt;ol&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Debounce&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Cache JS Files&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Compress resources (brotli, gzip)&lt;/li&gt;&lt;/ol&gt;&lt;li style=&quot;text-align: left;&quot;&gt;JS Performance&lt;/li&gt;&lt;ol&gt;&lt;li style=&quot;text-align: left;&quot;&gt;use web-worker (for formula parsing, other heavy task)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;writing optimal JS code&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Minify code&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Load JS async/defer&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;remove un-used code (tree-shaking)&lt;/li&gt;&lt;/ol&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Rendering Performance&lt;/li&gt;&lt;ol&gt;&lt;li style=&quot;text-align: left;&quot;&gt;show perception (loader)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;load non-critical stuffs later&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Direct update store/state from each individual cell and depend only on store for updates not on parent&#39;s component state&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;therefore direct O(1) cell updates instead of re-rendering every cells&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;prevent un-necessary re-renders using useCallback, useMemo, memo&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Virtualisation&lt;/li&gt;&lt;/ol&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="280" width="740" x="1170" y="610" as="geometry" />
        </mxCell>
