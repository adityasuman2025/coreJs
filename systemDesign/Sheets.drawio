        <mxCell id="v2OB34sA-GqR4EwWEd6K-24" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 style=&quot;caret-color: rgb(0, 0, 0); color: rgb(0, 0, 0); font-family: Helvetica; font-style: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-line: none; text-decoration-thickness: auto; text-decoration-style: solid; margin-top: 0px;&quot;&gt;Data Model&lt;/h1&gt;" vertex="1">
