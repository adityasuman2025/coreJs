  <diagram name="Page-1" id="fEw7YAjXA1syozRMgXxP">
    <mxGraphModel dx="2353" dy="1655" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="41rbekOjbsT3yBnaVnjB-2" parent="1" style="text;strokeColor=none;fillColor=none;html=1;fontSize=27;fontStyle=1;verticalAlign=middle;align=center;autosizeText=1;" value="Stock Broker Platform" vertex="1">
          <mxGeometry height="40" width="370" x="890" y="10" as="geometry" />
        </mxCell>
        <mxCell id="41rbekOjbsT3yBnaVnjB-3" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Functional Requirements&lt;/h1&gt;&lt;p&gt;1. Users should be able to see live price update of the stocks in their watchlist&lt;/p&gt;&lt;p&gt;2. User should be able to see price history + chart of a stock&lt;/p&gt;&lt;p&gt;3. User should be able to place order of a stock at any fixed price&lt;/p&gt;&lt;p&gt;4. User should see stocks in their portfolio, their live profit/loss&amp;nbsp;&lt;/p&gt;&lt;p&gt;5. Notification of success/failure status or placed order&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="390" x="425" y="90" as="geometry" />
        </mxCell>
        <mxCell id="41rbekOjbsT3yBnaVnjB-4" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Non-Functional Requirements&lt;/h1&gt;&lt;p&gt;1. 60fps rendering performance of live stock price updates&lt;/p&gt;&lt;p&gt;2. UI should be pessimistic, only show final state when get response from the server&lt;/p&gt;&lt;p&gt;4. User should be able to use/control the app from keyboard&lt;/p&gt;&lt;p&gt;5. App should be responsive&lt;/p&gt;" vertex="1">
          <mxGeometry height="210" width="390" x="425" y="290" as="geometry" />
        </mxCell>
        <mxCell id="41rbekOjbsT3yBnaVnjB-5" parent="1" style="text;strokeColor=none;fillColor=none;html=1;whiteSpace=wrap;verticalAlign=middle;overflow=hidden;" value="&lt;ol&gt;&lt;li&gt;Requirements&lt;/li&gt;&lt;li&gt;Tech Stack&lt;/li&gt;&lt;li&gt;Data Models&lt;/li&gt;&lt;ol&gt;&lt;li&gt;Data Model&lt;/li&gt;&lt;li&gt;Data Store Model&lt;/li&gt;&lt;li&gt;Component API&lt;/li&gt;&lt;li&gt;Backend API&lt;/li&gt;&lt;/ol&gt;&lt;li&gt;Component Architecture&lt;/li&gt;&lt;ol&gt;&lt;li&gt;Component Hierarchy&lt;/li&gt;&lt;li&gt;Dependency Graph&lt;/li&gt;&lt;/ol&gt;&lt;li&gt;Performance &amp;amp; Optimisation&lt;/li&gt;&lt;li&gt;Accessibility&lt;/li&gt;&lt;li&gt;Availiability&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="200" width="240" x="10" y="80" as="geometry" />
        </mxCell>
        <mxCell id="41rbekOjbsT3yBnaVnjB-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Tech Stack&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;Library: React (depends on team)&lt;br&gt;&lt;/li&gt;&lt;li&gt;State Management: Redux&lt;br&gt;&lt;/li&gt;&lt;li&gt;List Item: div DOM element (Virtualised List)&lt;br&gt;&lt;/li&gt;&lt;li&gt;Network Communication: HTTP Request, WebSocket (because here too communication is bi-directional - client will subscribe/un-subscribe the stocks for which they want the live updates&lt;br&gt;&lt;/li&gt;&lt;li&gt;3rd party packages: react-window, react-redux&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="200" width="310" x="30" y="330" as="geometry" />
